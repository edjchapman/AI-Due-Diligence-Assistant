{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    // "node" is here because the client imports API types from the server
    // source (src/checks.ts → src/db/*), whose transitive graph reads
    // process.env. Type-only imports are erased at build, so nothing
    // server-side reaches the bundle — but tsc still checks those files.
    "types": ["vite/client", "node", "@testing-library/jest-dom"]
  },
  "include": ["src"]
}
